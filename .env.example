# --- Server-side only (NEVER prefixed with VITE_, never shipped to the browser) ---
# Used by the BFF proxy: the Vercel functions in `api/` (set in the Vercel
# dashboard) and the Vite dev proxy in `vite.config.ts` (read from this file).
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY_HERE

# --- Client-side (VITE_ prefixed, inlined into the bundle) ---
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
VITE_YOUTUBE_REGION=IN

# Set to 'true' to use the built-in mock provider (no YouTube API quota consumed).
VITE_USE_MOCK_API=false

# Optional: error reporting. When set (prod builds only), errors are sent to Sentry.
# Leave empty to disable — the Sentry SDK is then never loaded at runtime.
VITE_SENTRY_DSN=

# Optional overrides — only needed if the proxy is hosted off-origin.
# VITE_API_BASE_URL=/api/youtube
# VITE_SUGGEST_URL=/api/suggest
